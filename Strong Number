#include <stdio.h>

int main() {
    int n = 145, temp = n;
    int sum = 0;

    for(; temp > 0; temp /= 10) {
        int digit = temp % 10;
        int fact = 1;

        for(int i = 1; i <= digit; i++)
            fact *= i;

        sum += fact;
    }

    if(sum == n)
        printf("Strong Number");
    else
        printf("Not Strong Number");

    return 0;
}
